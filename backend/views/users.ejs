<!DOCTYPE html>
<html>
<head>
  <title>Users</title>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>

  <h1>Registered Users</h1>

  <% if (users.length === 0) { %>
    <p>No users found.</p>
  <% } else { %>

    <table border="1" cellpadding="10">
      <tr>
        <th>ID</th>
        <th>Username</th>
        <th>Email</th>
      </tr>

      <% users.forEach(user => { %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.username %></td>
          <td><%= user.email %></td>
        </tr>
      <% }) %>

    </table>

  <% } %>

</body>
</html>