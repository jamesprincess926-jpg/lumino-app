<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LUMINO</title>  <!-- Correct CSS path (make sure folder is /styles/) -->  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>  <!-- HEADER -->  <header>
    <img src="/images/logo.png" alt="Lumino Logo" class="logo">
    <button><a href="#templates">Get Started</a></button>
  </header>  <!-- HERO SECTION -->  <section class="hero">
    <div class="hero-text">
      <h1>LUMINO</h1>
      <h2>Clarity to your business</h2>
      <p>Visibility and Sales Tracking for Small Businesses</p>
    </div>
  </section>  <!-- SALES SECTION -->  <section class="sales-section"><h1>Record Sales</h1>

<label for="product">Product Name:</label>
<input type="text" id="product" placeholder="Enter product name">

<label for="amount">Sale Amount:</label>
<input type="number" id="amount" placeholder="Enter amount">

<button onclick="addSale()" class="sales-but">Add Sale</button>

<label for="filter">Filter Sales:</label>
<select id="filter" onchange="renderSales()">
  <option value="all">All Time</option>
  <option value="today">Today</option>
  <option value="week">This Week</option>
  <option value="month">This Month</option>
</select>

<!-- TABLE -->
<div class="tcontainer">
  <table id="salesTable">
    <thead>
      <tr>
        <th>Date</th>
        <th>Product</th>
        <th>Amount</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>
</div>

<!-- TOTAL -->
<div id="totalSales">Total Sales: $0.00</div>

<!-- CARDS -->
<div class="cards">
  <div id="todayCard"></div>
  <div id="weekCard"></div>
  <div id="monthCard"></div>
</div>

  </section>  <!-- TEMPLATE SECTION -->  <section class="templates" id="templates"><div class="template-card" onclick="selectTemplate('Fashion/Shoes')">
  Fashion <br> / Shoes
</div>

<div class="template-card" onclick="selectTemplate('Food')">
  Food / Drinks
</div>

<div class="template-card" onclick="selectTemplate('Electronics/Gadgets')">
  Electronics <br> / Gadgets
</div>

<div class="template-card" onclick="selectTemplate('Skincare/Beauty')">
  Skincare <br> / Beauty
</div>

<div class="template-card" onclick="selectTemplate('Hair care/wigs')">
  Hair care / wigs
</div>

<div class="template-card" onclick="selectTemplate('Others')">
  Others
</div>

  </section>  <!-- FORM SECTION -->  <section class="form-section" id="formSection"><h2>Enter Business Details</h2>

<input type="text" id="name" placeholder="Business Name" class="input">

<textarea id="desc" placeholder="Business Description"></textarea>

<input type="text" id="contact" placeholder="Contact Info" class="input">

<button onclick="generateSite()" class="button-generate">
  Generate Website
</button>

  </section>  <!-- PREVIEW SECTION -->  <section class="preview" id="preview"><h2 id="pName"></h2>
<p id="pDesc"></p>
<p id="pContact"></p>

  </section>  <!-- JS (make sure path is correct) -->  <script src="/js/script.js"></script></body>
</html>