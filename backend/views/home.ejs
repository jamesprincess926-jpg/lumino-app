<!DOCTYPE html>
<html lang="en">
    <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>LUMINO</title>
      <link rel="stylesheet" href="/Styles/main.css">
    </head>
    
    <body>
      <header>
        <img src="/images/logo2.png" alt="">
        <button><a href="#templates">Get started</a></button>
      </header>
        
      <div class="hero">
        
        <div class="hero-text">
            <h1>LUMINO</h1>
            <h2>Clarity to your business</h2>
            <p>Visibility and Sales Tracking for Small Businesses</p>
        </div>
      </div>
      
      <!-- SALES SECTION ADDED -->
      
      <section class="sales-section">
        
        <h1>Record Sales</h1>
        <label for="product">Product 
        Name:</label> 
        
        <input type="text" id="product" 
        placeholder="Enter product name"
        >
        <label for="amount">Sale Amount
        :</label>
        
        <input type="number" id="amount"
        placeholder="Enter amount">
        
        <br>
        
        <button onclick="addSale()" 
        class="sales-but">Add Sale
        </button>
        
        <label for="filter">Filter Sales
        :</label>
        
        <br>
        
        <select id="filter" onchange="renderSales()">
          <option value="all">All Time</option>
          <option value="today">Today</option>
          <option value="week">This Week</option>
          <option value="month">This Month</option>
        </select>
        <div class="tcontainer">
          <table id="salesTable">
            <thead>
              <tr>
                <th>Date</th>
                <th>Product</th>
                <th>Amount</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <!-- Sales records appear here -->
            </tbody>
          </table>
        </div>
        
        
        <div id="totalSales">Total Sales
        : $0.00</div>

        <div class="cards">
          <div id="todayCard"></div>
          <div id="weekCard"></div>
          <div id="monthCard"></div>
        </div>




      </section>
      
      <section class="templates" id="templates">
        <div class="template-card" onclick="selectTemplate('Fashion/Shoes')">Fashion <br>/Shoes
        </div>
        
        <div class="template-card" onclick="selectTemplate('Food')">Food/ Drinks
        </div>
        
        <div class="template-card" onclick="selectTemplate('Electronics/Gadgets')">Electronics <br>/Gadgets
        </div>
        
        <div class="template-card" onclick="selectTemplate('Skincare/Beauty')">Skincare <br>/Beauty
        </div>
        
        <div class="template-card" onclick="selectTemplate('Hair care/wigs')">Hair care/wigs
        </div>
        
        <div class="template-card" onclick="selectTemplate('Others')">Others
        </div>
      </section>
      
      <section class="form-section" id="formSection">
        
        <h2>Enter Business Details</h2>
        
        <input type="text" id="name" placeholder="Business Name" class="input"
        
        <br>
        
        <textarea id="desc" placeholder="Business Description"</textarea>
        
        <br>
        
        <input type="text" id="contact" placeholder="Contact Info" class="input" >
        
        <br>
        
        <button onclick="generateSite()" class="button-generate">
          Generate Website
        </button>
      </section>
      
      <section class="preview" id="preview">
        <h2 id="pName"></h2>
        <p id="pDesc"></p>
        <p id="pContact"></p>
      </section>
      
      
      <script src="js/script.js"></script>
    </body>
</html>